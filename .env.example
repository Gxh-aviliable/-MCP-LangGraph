# === 模型 API 配置 ===

# DeepSeek API (R1 推理模型 - 用于复杂场景)
DEEPSEEK_API_KEY=sk-xxx

# 阿里云 DashScope API (Qwen3 主模型 + Embedding)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxx

# === 高德地图 API ===
AMAP_MAPS_API_KEY=xxx

# === 模型选择配置 ===
PRIMARY_MODEL=qwen-plus
REASONING_MODEL=deepseek-reasoner
LLM_TEMPERATURE=0.7

# === RAG 配置 ===
CHROMA_PERSIST_DIR=./data/travel_vectordb
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

# === MCP 服务器配置 (可选) ===
# MCP_CONFIG_PATH=backend/config/mcp_config.json

# === 应用配置 ===
APP_NAME=Travel Planning Agent
DEBUG=false

# === 服务器配置 ===
HOST=0.0.0.0
PORT=8000

# === 会话配置 ===
SESSION_EXPIRE_SECONDS=3600